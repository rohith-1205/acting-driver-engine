# Environment variables template for Acting Driver Matching Engine

# MongoDB URI connection string
MONGO_URI=mongodb://localhost:27017/publicrides

# Redis server hostname
REDIS_HOST=127.0.0.1
# Redis server port
REDIS_PORT=6379
# Redis connection password (if any)
REDIS_PASSWORD=

# BullMQ queue name for trip scheduling
SCHEDULER_QUEUE_NAME=ad_scheduler
# BullMQ queue name for driver matching
MATCHING_QUEUE_NAME=ad_matching
# BullMQ queue name for driver dispatching
DISPATCH_QUEUE_NAME=ad_dispatch
# BullMQ queue name for post-trip Redis cleanup
CLEANUP_QUEUE_NAME=ad_cleanup

# Port for Socket.IO gateway server
SOCKET_PORT=4001

# Port for Express API server
PORT=3001
# Node environment (development, production, testing)
NODE_ENV=development
# Region code suffix/prefix used for trip identification (e.g. CMR)
REGION_CODE=CMR

# Maximum number of matching rounds/attempts per trip (max 3)
MAX_MATCH_ATTEMPTS=3
# Duration in ms to wait for a driver response before timing out
DRIVER_RESPONSE_TIMEOUT_MS=15000
# Number of drivers to shortlist in each matching round
SHORTLIST_SIZE=5
# Maximum radius in kilometers to look up online drivers
MAX_DRIVER_SEARCH_RADIUS_KM=10

# Maximum cancellation retry attempts
MAX_CANCELLATION_RETRIES=3

# Calendar Conflict Buffer Configuration
# Minimum buffer rest required between scheduled trips (in milliseconds, e.g. 1 hour = 3600000)
PLATFORM_MINIMUM_BUFFER_MS=3600000
# Default buffer rest required between scheduled trips (in milliseconds, e.g. 2 hours = 7200000)
DEFAULT_BUFFER_MS=7200000
# Maximum buffer rest driver cap (in milliseconds, e.g. 8 hours = 28800000)
MAX_BUFFER_MS=28800000
# Average vehicle speed for travel time computation in km/h
AVERAGE_SPEED_KMPH=40

# Scoring Engine Weights (must sum to 100)
# Weight for distance score (e.g. 40)
SCORE_WEIGHT_DISTANCE=40
# Weight for driver rating score (e.g. 20)
SCORE_WEIGHT_RATING=20
# Weight for vehicle type handling capability match (e.g. 15)
SCORE_WEIGHT_VEHICLE_MATCH=15
# Weight for platform tenure experience (e.g. 10)
SCORE_WEIGHT_EXPERIENCE=10
# Weight for night driving capability if nightRide requested (e.g. 5)
SCORE_WEIGHT_NIGHT_DRIVING=5
# Weight for long distance driving capability if estimatedDistance > 50km (e.g. 5)
SCORE_WEIGHT_LONG_DISTANCE=5
# Weight for acceptance/rejection rate score (e.g. 5)
SCORE_WEIGHT_ACCEPTANCE_RATE=5


